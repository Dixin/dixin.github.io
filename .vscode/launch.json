{
	"version": "0.2.0",
	"configurations": [
		{
			"name": "Launch Astro Dev",
			"type": "node",
			"request": "launch",
			"runtimeArgs": ["dev"],
			"runtimeExecutable": "pnpm",
			"port": 4321,
			"console": "integratedTerminal",
			"internalConsoleOptions": "neverOpen"
		},
		{
			"command": "pnpm dev",
			"name": "Development server",
			"request": "launch",
			"type": "node-terminal"
		},
		{
			"command": "pnpm build",
			"name": "Build",
			"request": "launch",
			"type": "node-terminal"
		}
	]
}
